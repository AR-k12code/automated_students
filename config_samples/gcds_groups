    <maximumLogBytes>1073741824</maximumLogBytes>
    <logFileCount>1</logFileCount>
  </logging>
  <notification>
    <smtpRelay>smtp-relay.gmail.com</smtpRelay>
    <useSmtpTLS>true</useSmtpTLS>
    <fromAddress>noreply@samplefacultydomain.com</fromAddress>
