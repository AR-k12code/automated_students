        <serverType>ACTIVE_DIRECTORY</serverType>
        <connectMethod>STANDARD</connectMethod>
        <hostname>10.64.4.1</hostname>
        <port>389</port>
        <basedn>dc=sample,dc=local</basedn>
        <authType>SIMPLE</authType>
        <authUser>gcds-user</authUser>
        <authCredentialsEncrypted></authCredentialsEncrypted>
        <nonAddressPrimaryKeyAttrName>objectGUID</nonAddressPrimaryKeyAttrName>
        <emailAttrName>mail</emailAttrName>
        <ldapCredMachineName>TECH-VIRTUAL</ldapCredMachineName>
        <dominoWhiteSpaceReplaceChar>.</dominoWhiteSpaceReplaceChar>
